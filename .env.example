# ============================================================
# BURGER-HUB ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================
# Copy this file to .env or .env.local and fill in your values

# DATABASE CONFIGURATION (REQUIRED)
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# BACKEND CONFIGURATION (REQUIRED)
# Port for Express server (e.g., 3000, 8080)
PORT=

# Security: JWT secret for token signing (REQUIRED in production)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# FRONTEND CONFIGURATION (REQUIRED)
# Base path for routing (usually "/" for root deployment)
BASE_PATH=

# API endpoint for frontend to call
# In development: http://localhost:3000/api
# In production: https://api.yourdomain.com/api
VITE_API_BASE_URL=

# NODE ENVIRONMENT
# Values: development, production
NODE_ENV=development

# CORS CONFIGURATION (Optional, defaults provided)
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:5173,http://localhost:3000,https://yourdomain.com
# ALLOWED_ORIGINS=
